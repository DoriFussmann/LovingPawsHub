# Supabase
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — used for article and skeleton generation
ANTHROPIC_API_KEY=

# DataForSEO — used for keyword research
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Admin Auth — single password protecting all /admin routes
ADMIN_PASSWORD=

# Site URL — REQUIRED. Build will throw if this is missing.
# No trailing slash. For local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Article images (choose one provider, or leave both blank for no images) ────

# Unsplash — free stock photo search (50 req/hr on free tier)
# Get your key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# DALL-E 3 — AI image generation via OpenAI
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────

# Google Analytics 4 (optional — Vercel Analytics is included automatically)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Legacy bootstrap overrides ────────────────────────────────────────────────
# These are fallbacks used before the site_config table is populated.
# The canonical source of truth is now /admin/site-settings.
# Set these temporarily if you want values to appear before your first admin save.
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_INDUSTRY_NAME=
